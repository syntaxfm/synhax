{
	"name": "battle-mode",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"sync-generate": "drizzle-zero generate --format  -o ./src/sync/zero-schema.gen.ts",
		"auth-generate": "pnpx @better-auth/cli generate",
		"sync": "pnpm zero-cache-dev",
		"postinstall": "pnpm sync-generate",
		"push": "drizzle-kit push",
		"studio": "drizzle-kit studio",
		"sync-permissions": "zero-deploy-permissions -p ./src/sync/schema.ts"
	},
	"devDependencies": {
		"@sentry/vite-plugin": "^4.3.0",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/kit": "^2.43.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/pg": "^8.15.5",
		"drizzle-kit": "^0.31.5",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.39.8",
		"svelte-check": "^4.3.2",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vite": "^7.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@rocicorp/zero-sqlite3",
			"@sentry/cli",
			"esbuild",
			"protobufjs",
			"sharp",
			"workerd"
		]
	},
	"dependencies": {
		"@awesome.me/webawesome": "3.0.0-beta.6",
		"@aws-sdk/client-s3": "^3.901.0",
		"@aws-sdk/s3-request-presigner": "^3.901.0",
		"@rocicorp/zero": "^0.23.2025090100",
		"@sentry/sveltekit": "^10.17.0",
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/svelte-table": "npm:tanstack-table-8-svelte-5@^0.1",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.3.25",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.44.6",
		"drizzle-zero": "^0.14.2",
		"nanoid": "^5.1.6",
		"openai": "^6.1.0",
		"pg": "^8.16.3",
		"postgres": "^3.4.7",
		"svelte-highlight": "^7.8.4",
		"svelte-splitpanes": "^8.0.9",
		"zero-svelte": "^0.8.1"
	}
}
