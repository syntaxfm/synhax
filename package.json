{
	"name": "battle-mode",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"sync-generate": "drizzle-zero generate --format  -o ./src/sync/zero-schema.gen.ts",
		"auth-generate": "pnpx @better-auth/cli generate",
		"sync": "pnpm zero-cache-dev",
		"postinstall": "pnpm sync-generate",
		"push": "drizzle-kit push",
		"studio": "drizzle-kit studio",
		"sync-permissions": "zero-deploy-permissions -p ./src/sync/schema.ts"
	},
	"devDependencies": {
		"@sentry/vite-plugin": "^4.3.0",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.3",
		"@sveltejs/kit": "^2.38.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@types/pg": "^8.15.5",
		"drizzle-kit": "^0.31.4",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.38.10",
		"svelte-check": "^4.0.0",
		"tsx": "^4.20.5",
		"typescript": "^5.0.0",
		"vite": "^7.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@rocicorp/zero-sqlite3",
			"esbuild",
			"protobufjs"
		]
	},
	"dependencies": {
		"@awesome.me/webawesome": "3.0.0-beta.5",
		"@aws-sdk/client-s3": "^3.887.0",
		"@aws-sdk/s3-request-presigner": "^3.887.0",
		"@rocicorp/zero": "^0.22.2025081300",
		"@sentry/sveltekit": "^10.11.0",
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/svelte-table": "npm:tanstack-table-8-svelte-5@^0.1",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.3.9",
		"dotenv": "^17.2.2",
		"drizzle-orm": "^0.44.5",
		"drizzle-zero": "^0.14.0",
		"nanoid": "^5.1.5",
		"pg": "^8.16.3",
		"svelte-highlight": "^7.8.4",
		"svelte-splitpanes": "^8.0.9",
		"zero-svelte": "^0.3.5"
	}
}
