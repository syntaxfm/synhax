{
	"name": "battle-mode",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"sync-generate": "drizzle-zero generate --format  -o ./src/sync/zero-schema.gen.ts",
		"auth-generate": "pnpx @better-auth/cli generate",
		"sync": "pnpx zero-cache-dev",
		"postinstall": "pnpm sync-generate",
		"push": "drizzle-kit push",
		"sync-permissions": "zero-deploy-permissions -p ./src/sync/schema.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@types/pg": "^8.15.5",
		"drizzle-kit": "^0.31.4",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tsx": "^4.20.4",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@rocicorp/zero-sqlite3",
			"esbuild",
			"protobufjs"
		]
	},
	"dependencies": {
		"@awesome.me/webawesome": "3.0.0-beta.4",
		"@aws-sdk/client-s3": "^3.864.0",
		"@aws-sdk/s3-request-presigner": "^3.864.0",
		"@rich_harris/svelte-split-pane": "^2.0.0",
		"@rocicorp/zero": "^0.22.2025081300",
		"better-auth": "^1.3.7",
		"dotenv": "^17.2.1",
		"drizzle-orm": "^0.44.4",
		"drizzle-zero": "^0.13.3",
		"nanoid": "^5.1.5",
		"pg": "^8.16.3",
		"svelte-highlight": "^7.8.3",
		"svelte-splitpanes": "^8.0.9",
		"zero-svelte": "^0.3.5"
	}
}
